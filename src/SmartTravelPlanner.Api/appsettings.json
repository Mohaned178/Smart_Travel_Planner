{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ExternalApis": {
    "OpenWeather": {
      "BaseUrl": "https://api.openweathermap.org/data/2.5/",
      "ApiKey": ""
    },
    "GooglePlaces": {
      "BaseUrl": "https://maps.googleapis.com/maps/api/place/",
      "ApiKey": ""
    },
    "OpenRouteService": {
      "BaseUrl": "https://api.openrouteservice.org/",
      "ApiKey": "",
      "Profile": "driving-car"
    },
    "Nominatim": {
      "BaseUrl": "https://nominatim.openstreetmap.org/",
      "UserAgent": "SmartTravelPlanner/1.0"
    },
    "Frankfurter": {
      "BaseUrl": "https://api.frankfurter.app/"
    }
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "SmartTravelPlanner",
    "Audience": "SmartTravelPlannerClients",
    "ExpirationMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=SmartPlanner;Username=postgres;Password="
  },
  "Caching": {
    "PlaceCacheExpirationDays": 7,
    "WeatherCacheExpirationHours": 6,
    "ExchangeRateCacheExpirationHours": 24,
    "DraftExpirationHours": 24
  },
  "TransportRates": {
    "PublicTransportPerKm": 0.15,
    "MealCostEstimates": {
      "Budget": 8.00,
      "Mid": 20.00,
      "Upscale": 45.00
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5500",
      "http://127.0.0.1:5500"
    ]
  }
}